# =============================================================
# Academic Climate Action Dashboard — Root .gitignore
# =============================================================

# ── Environment Variables (NEVER commit these) ────────────────
.env
.env.local
.env.development
.env.production
.env.staging
backend/.env
client/.env

# ── Node Modules ──────────────────────────────────────────────
node_modules/
backend/node_modules/
client/node_modules/

# ── Build Output ──────────────────────────────────────────────
dist/
build/
client/dist/
backend/dist/
*.tsbuildinfo

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS & Editor Files ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo

# ── Vite / React ──────────────────────────────────────────────
client/.vite/
client/coverage/

# ── Misc ──────────────────────────────────────────────────────
.cache/
.temp/
*.zip
*.tar.gz
